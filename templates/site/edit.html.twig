{% extends 'base.html.twig' %}

{% block title %} {{ parent() }} | Gestion des sites {% endblock %}

{% block body %}

    <h2 class="text-center p-3">Gérer les sites</h2>

    {{ form_start(site_form, {'attr': {'data-turbo': 'false'}}) }}
    <table class="table">
        <thead class="thead-dark">
                <tr>
                    <th>Nom du site</th>
                    <th>Nombre de participants</th>
                    <th>Action</th>
                </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="2">
                    {{ form_widget(site_form.nomSite) }}
                    {{ form_errors(site_form.nomSite) }}
                </td>
                <td>
                    <button class="btn btn-primary" type="submit" value="create" name="create">
                        Ajouter
                    </button>
                </td>
            </tr>
            {{ form_end(site_form) }}
            {% for site in sites %}
                <tr>
                    <td>
                        <span id="nom-{{ site.id }}"> {{ site.nomSite }}</span>
                        <form action="{{ path('app_site_update', {id: site.id}) }}" method="POST">
                            <input type="hidden" name="_token" value="{{ csrf_token('update'~site.id) }}">
                            <input type="text" name="nomSite" value="{{ site.nomSite }}" class="form-control d-none" id="input-{{ site.id }}">
                            <button type="submit" class="btn btn-success btn-sm d-none" value="update" name="update" id="button-{{ site.id }}">
                                Enregistrer </button>
                            <button type="button"
                                    class="btn btn-secondary btn-sm d-none"
                                    value="cancel"
                                    name="cancel"
                                    id="cancel-{{ site.id }}"
                                    onclick="document.getElementById('input-{{ site.id }}').classList.add('d-none');
                                    document.getElementById('button-{{ site.id }}').classList.add('d-none');
                                    document.getElementById('cancel-{{ site.id }}').classList.add('d-none');
                                    document.getElementById('nom-{{ site.id }}').classList.remove('d-none') "
                            >Annuler </button>
                        </form>
                    </td>
                    <td>
                        <span>{{ site.participants.count }}</span>
                    </td>
                    <td>
                        <button type="button"
                            class="btn btn-warning"
                            onclick="document.getElementById('nom-{{ site.id }}').classList.add('d-none');
                            document.getElementById('input-{{ site.id }}').classList.remove('d-none');
                            document.getElementById('button-{{ site.id }}').classList.remove('d-none');
                            document.getElementById('cancel-{{ site.id }}').classList.remove('d-none');"
                        >Modifier
                        </button>
                        <a href="{{ path('app_site_delete', {id: site.id, _token: csrf_token('delete' ~ site.id)}) }}"
                              class="btn btn-danger"
                              onclick="return confirm('Etes-vous sûr de vouloir supprimer ce site ?')"
                        >Supprimer
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

{% endblock %}
