{% for data in tableau %}
    <tr>
        <td>{{ data.nom }}</td>
        <td>{{ data.dateHeureDebut|date('d/m/Y H:i')}}</td>
        <td>{{ data.dateLimiteInscription|date('d/m/Y')}}</td>
        <td>{{ data.nbInscrits~'/'~data.nbInscriptionMax }}</td>
        <td>{{ data.etat }}</td>
        <td>{{ data.inscrit }}</td>
        <td><a href="{{ path('app_profile_show', { id: data.idOrganisateur }) }}">{{ data.organisateur }}</a></td>
        <td>
            {% if data.etat == 'Ouverte' %}
                {% if is_granted('ROLE_ADMIN') %}
                    <strong> - </strong><a href="{{ path('app_sortie_cancel', { id: data.id}) }}">Annuler</a>
                {% endif %}
                {% if data.inscrit != 'X' and data.dateLimiteInscription > date() and (is_granted('ROLE_ADMIN') or data.idOrganisateur == app.user.id)  %}
                    <strong> - </strong><a href="{{ path('app_home_inscrire', { idSortie: data.id}) }}"
                       onclick="return confirm('Etes vous vraiment sûr de vouloir vous inscrire a cette sortie : {{ data.nom }} ?')">
                        S'inscrire
                    </a>
                {% endif %}
            {% endif %}
            {% if data.etat == 'Créée' %}
                {% if is_granted('ROLE_ADMIN') or (data.idOrganisateur == app.user.id) %}
                    <strong> - </strong>
                    <a href="{{ path('app_sortie_update', { id: data.id}) }}">Modifier</a>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <strong> - </strong>
                    <a href="{{ path('app_home_publier', { idSortie: data.id}) }}"
                       onclick="return confirm('Etes vous vraiment sûr de vouloir publier cette sortie : {{ data.nom }} ?')">
                        Publier
                    </a>
                {% endif %}
            {% endif %}
            {% if data.inscrit == 'X' %}
                <strong> - </strong>
                <a href="{{ path('app_home_desister', { idSortie: data.id}) }}"
                   onclick="return confirm('Etes vous vraiment sûr de vouloir vous désister de la sortie {{ data.nom }} ?')">
                    Se Désister
                </a>
            {% endif %}
            <strong> - </strong>
            <a href="{{ path('app_sortie_detail', { id: data.id}) }}">Afficher</a>
        </td>
        <td>{{ data.site }}</td>
    </tr>
{% endfor %}
