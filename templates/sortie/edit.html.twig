{% extends 'base.html.twig' %}

{% block title %}
    {% if isEdit %}
        Modifier une sortie | {{ parent() }}
    {% else %}
        Créer une sortie | {{ parent() }}
    {% endif %}

{% endblock %}

{% block body %}
    {% if isEdit %}
        <h2 class="text-center p-2">Modifier une sortie</h2>
    {% else %}
        <h2 class="text-center p-2">Créer une sortie</h2>
    {% endif %}
    <div class="row justify-content-center">
        <div class="col-12 col-md-8">

            {{ form_start(sortie_form) }}
            {{ form_errors(sortie_form) }}
            {{ form_widget(sortie_form.lieux, {'attr': {'class': 'form-select d-none'}}) }}

            <div class="group required-label">
                {{ form_label(sortie_form.nom) }}
                {{ form_widget(sortie_form.nom) }}
                {{ form_errors(sortie_form.nom) }}
            </div>
            <div class="group required-label">
                {{ form_label(sortie_form.dateHeureDebut) }}
                {{ form_widget(sortie_form.dateHeureDebut) }}
                {{ form_errors(sortie_form.dateHeureDebut) }}
             </div>
            <div class="group required-label">
                {{ form_label(sortie_form.dateLimiteInscription) }}
                {{ form_widget(sortie_form.dateLimiteInscription) }}
                {{ form_errors(sortie_form.dateLimiteInscription) }}
            </div>
            <div class="group required-label">
                {{ form_label(sortie_form.duree) }}
                <div class="input-group">
                    {{ form_widget(sortie_form.duree, {'attr': {'class': 'form-control'}}) }}
                    <span class="input-group-text">minutes</span>
                </div>
                {{ form_errors(sortie_form.duree) }}
            </div>
            <div class="group required-label">
                {{ form_label(sortie_form.nbInscriptionMax) }}
                {{ form_widget(sortie_form.nbInscriptionMax) }}
                {{ form_errors(sortie_form.nbInscriptionMax) }}
            </div>
            <div class="group required-label">
                {{ form_label(sortie_form.infosSortie) }}
                {{ form_widget(sortie_form.infosSortie) }}
                {{ form_errors(sortie_form.infosSortie) }}
            </div>
            <br>
            <p class="card-body pt-0">Site organisateur : {{ sortie.organisateur.sites.nomSite }}</p>
            <div class="group required-label">
                {{ form_label(sortie_form.villes) }}
                {{ form_widget(sortie_form.villes) }}
                {{ form_errors(sortie_form.villes) }}
            </div>
            <div class="group required-label">
                {{ form_label(sortie_form.lieux) }}
                <div><select class="form-select" id="lieu-select">
                        <option value="">--Sélectionner un lieu--</option>
                    </select>
                </div>
                {{ form_errors(sortie_form.lieux) }}
                <br>

                <!-- Bouton déclencheur -->
                <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#maPopin">
                    Ajouter un lieu
                </button>

            </div>
            <br>
            <p class="card-body pt-0">Rue : <span id="lieu-rue"></span></p>
            <p class="card-body pt-0">Code postal : <span id="lieu-cp"></span></p>
            <br>
            <div class="text-center">
                <button type="submit" class="btn btn-primary" value="creer" name="creer">
                    Enregistrer
                </button>
                <button type="submit" class="btn btn-warning" value="publier" name="publier">
                    Publier la sortie
                </button>
                <button type="reset" class="btn btn-secondary">
                    Annuler
                </button>
                {% if isEdit %}
                <a href="{{ path('app_sortie_delete', {id: sortie.id, _token: csrf_token('delete' ~ sortie.id)}) }}"
                   class="btn btn-danger"
                   onclick="return confirm('Etes-vous sûr de vouloir supprimer cette sortie ?')"
                >Supprimer</a>
                {% endif %}
            </div>
            {{ form_end(sortie_form) }}

            <!-- La popin -->
            <div class="modal fade" id="maPopin" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Ajouter un lieu</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            {{ form_start(lieu_form, {'attr': {'data-turbo': 'false', 'data-turbo-stream': 'false'}}) }}

                            {{ form_label(lieu_form.nomLieu) }}
                            {{ form_widget(lieu_form.nomLieu) }}
                            {{ form_errors(lieu_form.nomLieu) }}

                            {{ form_label(lieu_form.rue) }}
                            {{ form_widget(lieu_form.rue) }}
                            {{ form_errors(lieu_form.rue) }}

                            {{ form_label(lieu_form.villes) }}
                            {{ form_widget(lieu_form.villes) }}
                            {{ form_errors(lieu_form.villes) }}

                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                <button type="submit" class="btn btn-primary" value="creerLieu" name="creerLieu">
                                    Enregistrer
                                </button>
                            </div>
                            {{ form_end(lieu_form) }}

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <br>
    <script type="module">
        import { initVilleSelect, initLieuSelect, initLieuForm, initEditMode } from '{{ asset('js/sortie.js') }}';

        initVilleSelect();
        initLieuSelect();
        initLieuForm();
        {% if isEdit %}
        initEditMode({{ sortie.lieux.villes.id }}, {{ sortie.lieux.id }});
        {% endif %}

    </script>
{% endblock %}
